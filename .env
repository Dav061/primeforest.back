# ============================================
# Django настройки
# ============================================

# Секретный ключ
SECRET_KEY=django-insecure-primeforest-backend-2024-secret-key-change-me

# Режим отладки (ВРЕМЕННО True для отладки)
DEBUG=True

# Разрешенные хосты (упрощено для локальной разработки)
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# База данных PostgreSQL
# ============================================

DB_NAME=primeforest_db
DB_USER=primeforest_user
DB_PASSWORD=StrongPassword123!
DB_HOST=postgres
DB_PORT=5432

# ============================================
# CORS настройки (упрощено для локальной разработки)
# ============================================

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
